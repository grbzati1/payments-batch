    },
    {
      "name": "Create Batch Idempotency Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Duplicate returns same batch', function () { pm.expect(pm.response.code).to.eql(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.batchId).to.eql(pm.environment.get('batchId'));",
              "pm.expect(json.duplicate).to.eql(true);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
