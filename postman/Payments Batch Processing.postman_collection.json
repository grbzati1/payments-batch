  "item": [
    {
      "name": "Healthcheck",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health/ready",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health",
            "ready"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Batch",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set('requestId', crypto.randomUUID());"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or 200', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
              "const json = pm.response.json();",
              "pm.expect(json.batchId).to.exist;",
              "pm.environment.set('batchId', json.batchId);",
              "pm.expect(json.status).to.eql('Draft');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Request-Id",
            "value": "{{requestId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientBatchReference\": \"APR-2026-001\",\n  \"payments\": [\n    {\n      \"clientPaymentReference\": \"PAY-001\",\n      \"currency\": \"USD\",\n      \"amount\": 100.25,\n      \"beneficiaryName\": \"Acme Ltd\",\n      \"destinationAccount\": \"US123456789\"\n    },\n    {\n      \"clientPaymentReference\": \"PAY-002\",\n      \"currency\": \"GBP\",\n      \"amount\": 220.00,\n      \"beneficiaryName\": \"Beta Ltd\",\n      \"destinationAccount\": \"GB987654321\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/batches",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "batches"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Submit Batch",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Submit succeeded', function () { pm.expect(pm.response.code).to.eql(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.status).to.eql('Submitted');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/batches/{{batchId}}/submit",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "batches",
            "{{batchId}}",
            "submit"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Batch",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Batch returned', function () { pm.expect(pm.response.code).to.eql(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.id).to.eql(pm.environment.get('batchId'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/batches/{{batchId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "batches",
            "{{batchId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Batch Payments",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Payments returned', function () { pm.expect(pm.response.code).to.eql(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.length).to.be.greaterThan(0);",
              "pm.environment.set('paymentId', json[0].id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/batches/{{batchId}}/payments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "batches",
            "{{batchId}}",
            "payments"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Payment",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/payments/{{paymentId}}",
          "host": [
